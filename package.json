{
  "name": "fisis-mcp",
  "version": "0.2.1",
  "description": "MCP server for FISIS (금융감독원 금융통계정보시스템) — Korean financial institution statistics for AI agents",
  "type": "module",
  "bin": {
    "fisis-mcp": "dist/src/index.js"
  },
  "main": "dist/src/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('dist/src/index.js', 0o755)\"",
    "dev": "tsc --watch",
    "test": "vitest run",
    "verify-presets": "node dist/scripts/verify-presets.js",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "fisis",
    "fss",
    "korea",
    "finance",
    "statistics",
    "금융감독원"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/namojo/fisis-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/namojo/fisis-mcp/issues"
  },
  "homepage": "https://github.com/namojo/fisis-mcp#readme",
  "author": "namojo"
}